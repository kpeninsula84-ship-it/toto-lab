# Copy this file to .env and fill in the values.
# DO NOT commit .env — it's gitignored. In CI, deploy.yml recreates this
# file from GitHub Actions secrets at deploy time.
#
# Note: no ANTHROPIC_API_KEY anywhere. AI analysis runs in worker/ on
# GitHub Actions via the headless Claude Code CLI under the user's
# subscription. Cloud Functions do no AI calls.

# football-data.org (https://www.football-data.org/client/register)
# Free tier: 10 req/min, includes Premier League current season.
# Used by collectFixtures and collectResults.
FOOTBALL_DATA_TOKEN=

# The Odds API (https://the-odds-api.com) — free tier 500 credits/month.
# Used by the GitHub Actions worker, not by Cloud Functions; kept here
# so deploy.yml writes a complete .env.
ODDS_API_KEY=

# Admin token for manual HTTP triggers (sent as `x-admin-token` header).
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Telegram bot alert (optional — leave blank to disable)
# 1. Create bot: @BotFather → /newbot → copy token
# 2. Start a chat with the bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates → copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
