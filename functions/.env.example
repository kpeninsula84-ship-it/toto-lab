# Copy this file to .env and fill in the values.
# DO NOT commit .env — it's gitignored.

# Anthropic Claude API (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# football-data.org (https://www.football-data.org/client/register)
# Free tier: 10 req/min, includes Premier League current season
FOOTBALL_DATA_TOKEN=

# The Odds API (https://the-odds-api.com/)
# Free tier: 500 requests/month, sport key: soccer_epl
ODDS_API_KEY=
