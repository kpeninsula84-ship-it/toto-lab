<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>app.aidebate</string>

  <!-- Boot ai-debate via `npm start`, which runs server + client
       concurrently. ai-debate is shared infra (totolab worker calls
       /api/analyze on port 3000, web UI used directly from browser),
       so both sides need to be up at all times. -->
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/npm</string>
    <string>start</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/dw/Projects/ai-debate</string>

  <!-- Restart on crash; start at login. -->
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>

  <!-- Cooldown to avoid spin-loop if startup itself fails. -->
  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>/tmp/aidebate.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/aidebate.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
